# LLM provider: openai | anthropic | google (default: openai)
LLM_PROVIDER=openai

# --- OpenAI (when LLM_PROVIDER=openai) ---
# Required: API key (server-side only — never expose to the browser)
OPENAI_API_KEY=sk-...
# Optional: model id (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
# Optional (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Google Gemini (when LLM_PROVIDER=google) ---
GOOGLE_API_KEY=
# Optional (default: gemini-2.0-flash)
GOOGLE_MODEL=gemini-2.0-flash

# SQLite database file path (default: ./data/interview-coach.db)
DATABASE_PATH=./data/interview-coach.db

# Optional: passphrase used to encrypt API keys stored via /settings (AES-256-GCM).
# Any string; keep stable if you already saved keys. Leave unset to use .env keys only.
SETTINGS_ENCRYPTION_KEY=your-encryption-key
